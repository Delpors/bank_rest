<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.31.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1773573347822-1" author="1101001">
        <createSequence incrementBy="1" sequenceName="cards_id_seq" startValue="1"/>
    </changeSet>
    <changeSet id="1773573347822-2" author="1101001">
        <createSequence incrementBy="1" sequenceName="transactions_id_seq" startValue="1"/>
    </changeSet>
    <changeSet id="1773573347822-3" author="1101001">
        <createSequence incrementBy="1" sequenceName="users_id_seq" startValue="1"/>
    </changeSet>
    <changeSet id="1773573347822-4" author="1101001">
        <createTable tableName="cards">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="cards_pkey"/>
            </column>
            <column name="active" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="deleted" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp"/>
            <column name="balance" type="NUMBER(38, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="block_reason" type="VARCHAR(255)"/>
            <column name="blocked_at" type="timestamp"/>
            <column name="card_holder_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="card_number" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="expire_date" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="SMALLINT">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1773573347822-5" author="1101001">
        <createTable tableName="transactions">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="transactions_pkey"/>
            </column>
            <column name="amount" type="NUMBER(38, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="transaction_number" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="from_card_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="to_card_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1773573347822-6" author="1101001">
        <createTable tableName="users">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="users_pkey"/>
            </column>
            <column name="active" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="deleted" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp"/>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="full_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="rol" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="user_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1773573347822-7" author="1101001">
        <addUniqueConstraint columnNames="email" constraintName="uk6dotkott2kjsp8vw4d0m25fb7" tableName="users"/>
    </changeSet>
    <changeSet id="1773573347822-8" author="1101001">
        <addUniqueConstraint columnNames="full_name" constraintName="ukin1xa1v3pcuete8f8lxa47btl" tableName="users"/>
    </changeSet>
    <changeSet id="1773573347822-9" author="1101001">
        <addUniqueConstraint columnNames="user_name" constraintName="ukk8d0f2n7n88w1a16yhua64onx" tableName="users"/>
    </changeSet>
    <changeSet id="1773573347822-10" author="1101001">
        <addUniqueConstraint columnNames="card_holder_name" constraintName="ukq3dc33i6tku1mc78nou9f7bt3"
                             tableName="cards"/>
    </changeSet>
    <changeSet id="1773573347822-11" author="1101001">
        <addUniqueConstraint columnNames="card_number" constraintName="ukqualp9iflk959u561wanavuj1" tableName="cards"/>
    </changeSet>
    <changeSet id="1773573347822-12" author="1101001">
        <addUniqueConstraint columnNames="password" constraintName="ukr53o2ojjw4fikudfnsuuga336" tableName="users"/>
    </changeSet>
    <changeSet id="1773573347822-13" author="1101001">
        <addForeignKeyConstraint baseColumnNames="from_card_id" baseTableName="transactions"
                                 constraintName="fk2rjf7q3aokek0bc3817l80p77" onDelete="NO ACTION"
                                 referencedColumnNames="id" referencedTableName="cards"/>
    </changeSet>
    <changeSet id="1773573347822-14" author="1101001">
        <addForeignKeyConstraint baseColumnNames="user_id" baseTableName="cards"
                                 constraintName="fkcmanafgwbibfijy2o5isfk3d5" onDelete="NO ACTION"
                                 referencedColumnNames="id" referencedTableName="users"/>
    </changeSet>
    <changeSet id="1773573347822-15" author="1101001">
        <addForeignKeyConstraint baseColumnNames="to_card_id" baseTableName="transactions"
                                 constraintName="fkrjipfg1tkqdhun7vvoe5m6rca" onDelete="NO ACTION"
                                 referencedColumnNames="id" referencedTableName="cards"/>
    </changeSet>

</databaseChangeLog>